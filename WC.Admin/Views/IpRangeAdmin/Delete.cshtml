@model WC.Models.Admin.IpRangeEditModel

@{
    ViewData["Title"] = "Delete IP Range";
}

<h1>Delete IP Range</h1>

<div class="alert alert-warning">
    Are you sure you want to delete this IP range?
</div>

<dl class="row">
    <dt class="col-sm-2">Country</dt>
    <dd class="col-sm-10">@Model.CountryName</dd>

    <dt class="col-sm-2">IP Version</dt>
    <dd class="col-sm-10">@Model.IpVersionString</dd>

    <dt class="col-sm-2">Start IP</dt>
    <dd class="col-sm-10">@Model.StartIp</dd>

    <dt class="col-sm-2">End IP</dt>
    <dd class="col-sm-10">@Model.EndIp</dd>
</dl>

<form asp-action="DeleteConfirmed" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>